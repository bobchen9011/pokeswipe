# ── Frontend (Vite exposes these at build time) ────────────────────────────────
# Used by the browser to fetch images from Cloudinary CDN
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset

# ── Server-side (Netlify Functions – never exposed to the browser) ─────────────
# Used by netlify/functions/upload.js to upload images securely
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset
